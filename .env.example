# 必填：用于身份认证
ANTHROPIC_API_KEY=your_api_key_here

# 选填：备用 API key，用于主 key 失败或冷却时轮换
# ANTHROPIC_API_KEY_BACKUP=your_backup_api_key_here
# ANTHROPIC_API_KEY_EMERGENCY=your_emergency_api_key_here

# 选填：指定模型 ID
MODEL_ID=claude-3-5-sonnet-20241022

# 选填：fallback 模型链，逗号分隔；未设置时不启用 fallback
# FALLBACK_MODEL_IDS=claude-haiku-4-20250514,claude-3-5-haiku-20241022

# 选填：如需接入兼容代理或网关，可设置自定义 Base URL
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# 选填：本地 HTTP Webhook 监听配置
HTTP_WEBHOOK_HOST=127.0.0.1
HTTP_WEBHOOK_PORT=50001
HTTP_WEBHOOK_PATH=/webhook
